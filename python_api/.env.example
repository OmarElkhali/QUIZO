# ============================================
# QUIZO Backend — Fichier d'environnement exemple
# ============================================
# cp .env.example .env
# ⚠️  NE COMMITTEZ JAMAIS votre fichier .env
# ============================================

# ---------- Flask ----------
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
LOG_LEVEL=INFO

# ---------- Firebase Admin ----------
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIREBASE_PROJECT_ID=your_firebase_project_id

# ---------- Clés API IA ----------
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here
QWEN_API_KEY=your_qwen_dashscope_api_key_here

# ---------- Modèles IA (optionnel) ----------
OPENROUTER_MODEL=qwen/qwen3.6-flash
OPENROUTER_QWEN_MODEL=qwen/qwen3.6-flash
GROQ_MODEL=qwen/qwen3-32b
GROQ_BASE_URL=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ---------- Limites beta gratuite ----------
MAX_UPLOAD_SIZE_MB=10
MAX_AI_QUESTIONS_PER_QUIZ=20

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
