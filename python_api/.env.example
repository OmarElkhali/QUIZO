# ============================================
# QUIZO Backend — Fichier d'environnement exemple
# ============================================
# cp .env.example .env
# ⚠️  NE COMMITTEZ JAMAIS votre fichier .env
# ============================================

# ---------- Flask ----------
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
LOG_LEVEL=INFO

# ---------- Firebase Admin ----------
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIREBASE_PROJECT_ID=your_firebase_project_id

# ---------- Clés API IA ----------
# Gemini (Par défaut)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (Ultra-rapide et performant)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_RETRIES=3
GROQ_RETRY_DELAY=1.0

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# Qwen DashScope
QWEN_API_KEY=your_qwen_dashscope_api_key_here
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ChatGPT / OpenAI
CHATGPT_API_KEY=your_openai_api_key_here

# ---------- Configuration Ollama (LLM Local - GRATUIT et PRIVÉ) ----------
# Pour utiliser des modèles open-source en local
# Installation : https://ollama.com/download
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Modèles recommandés pour QUIZO :
#   - qwen2.5:7b (recommandé - excellent français, 4.7 GB)
#   - llama3.1:8b (très bon multilingue, 5 GB)
#   - mistral:7b (rapide et performant en français, 4.1 GB)
#   - phi3:mini (léger pour PC modestes, 2.3 GB)
#   - qwen2.5:14b (meilleure qualité si bon GPU, 8.5 GB)

# ---------- Limites beta gratuite ----------
MAX_UPLOAD_SIZE_MB=10
MAX_AI_QUESTIONS_PER_QUIZ=20

# ---------- Configuration CORS (liste séparée par des virgules) ----------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,https://your-production-domain.com
