rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signed() {
      return request.auth != null;
    }

    function isOwner(data) {
      return signed() && (
        data.get('creatorId', '') == request.auth.uid ||
        data.get('ownerId', '') == request.auth.uid ||
        data.get('userId', '') == request.auth.uid
      );
    }

    function isCollaborator(data) {
      return signed() && (
        data.get('collaboratorUids', []).hasAny([request.auth.uid]) ||
        data.get('collaborators', []).hasAny([request.auth.uid])
      );
    }

    function isByCode(data) {
      return data.get('visibility', '') == 'by_code' ||
        data.get('isPublic', false) == true ||
        data.get('shareCode', '') != '';
    }

    function sameExistingUser() {
      return request.resource.data.userId == resource.data.userId;
    }

    function quizData(quizId) {
      return get(/databases/$(database)/documents/quizzes/$(quizId)).data;
    }

    function competitionData(competitionId) {
      return get(/databases/$(database)/documents/competitions/$(competitionId)).data;
    }

    match /users/{userId} {
      allow read, create, update: if signed() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /shareCodes/{code} {
      allow get: if signed();
      allow list: if false;
      allow create: if signed() && request.resource.data.ownerId == request.auth.uid;
      allow update: if signed() &&
        resource.data.ownerId == request.auth.uid &&
        request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if signed() && resource.data.ownerId == request.auth.uid;
    }

    match /quizzes/{quizId} {
      allow create: if signed() && isOwner(request.resource.data);
      allow get: if signed() && (
        isOwner(resource.data) ||
        isCollaborator(resource.data) ||
        isByCode(resource.data)
      );
      allow list: if signed();
      allow update, delete: if signed() && isOwner(resource.data);

      match /participants/{participantId} {
        allow create: if signed() &&
          participantId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid &&
          (isByCode(quizData(quizId)) || isOwner(quizData(quizId)));

        allow get: if signed() && (
          isOwner(quizData(quizId)) ||
          request.auth.uid == participantId ||
          request.auth.uid == resource.data.userId
        );

        allow list: if signed() && isOwner(quizData(quizId));

        allow update: if signed() && (
          isOwner(quizData(quizId)) ||
          request.auth.uid == resource.data.userId
        ) && sameExistingUser();

        allow delete: if signed() && isOwner(quizData(quizId));
      }

      match /attempts/{attemptId} {
        allow create: if signed() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.participantId == request.auth.uid &&
          (isByCode(quizData(quizId)) || isOwner(quizData(quizId)));

        allow get: if signed() && (
          isOwner(quizData(quizId)) ||
          request.auth.uid == resource.data.userId
        );

        allow list: if signed() && isOwner(quizData(quizId));

        allow update: if signed() && (
          isOwner(quizData(quizId)) ||
          request.auth.uid == resource.data.userId
        ) && sameExistingUser();

        allow delete: if signed() && isOwner(quizData(quizId));
      }
    }

    match /competitions/{competitionId} {
      allow create: if signed() && request.resource.data.creatorId == request.auth.uid;
      allow get: if signed() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.get('shareCode', '') != '' ||
        resource.data.get('isActive', false) == true
      );
      allow list: if signed();
      allow update, delete: if signed() && resource.data.creatorId == request.auth.uid;

      match /participants/{participantId} {
        allow create: if signed() &&
          participantId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid &&
          competitionData(competitionId).get('shareCode', '') != '';

        allow get: if signed() && (
          competitionData(competitionId).creatorId == request.auth.uid ||
          request.auth.uid == participantId ||
          request.auth.uid == resource.data.userId ||
          competitionData(competitionId).get('shareCode', '') != ''
        );

        allow list: if signed() && competitionData(competitionId).get('shareCode', '') != '';

        allow update: if signed() && (
          competitionData(competitionId).creatorId == request.auth.uid ||
          request.auth.uid == resource.data.userId
        ) && sameExistingUser();

        allow delete: if signed() && competitionData(competitionId).creatorId == request.auth.uid;
      }

      match /attempts/{attemptId} {
        allow create: if signed() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.participantId == request.auth.uid &&
          competitionData(competitionId).get('shareCode', '') != '';

        allow get: if signed() && (
          competitionData(competitionId).creatorId == request.auth.uid ||
          request.auth.uid == resource.data.userId
        );

        allow list: if signed() && competitionData(competitionId).creatorId == request.auth.uid;

        allow update: if signed() && (
          competitionData(competitionId).creatorId == request.auth.uid ||
          request.auth.uid == resource.data.userId
        ) && sameExistingUser();

        allow delete: if signed() && competitionData(competitionId).creatorId == request.auth.uid;
      }
    }

    match /quizResults/{resultId} {
      allow create: if signed() && request.resource.data.userId == request.auth.uid;
      allow get: if signed() && (
        request.auth.uid == resource.data.userId ||
        isOwner(quizData(resource.data.quizId))
      );
      allow list: if signed();
      allow update: if signed() &&
        request.auth.uid == resource.data.userId &&
        sameExistingUser();
      allow delete: if false;
    }

    match /submissions/{submissionId} {
      allow create: if signed() && request.resource.data.userId == request.auth.uid;
      allow get: if signed() && request.auth.uid == resource.data.userId;
      allow list: if signed();
      allow update: if signed() &&
        request.auth.uid == resource.data.userId &&
        sameExistingUser();
      allow delete: if false;
    }

    match /backup-questions/{docId} {
      allow read: if signed();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
